    "# Declaración de lista de datos\n",
    "ventas = [800, 1500, 950, 1000, 1300, 2500]\n",
    "# Ventas válidas\n",
    "ventas_validas = [ venta for venta in ventas if venta < 1000]\n",
    "# Imprimir resultados\n",
    "print(f\"Ventas procesadas sin errores {ventas_validas}\")"
   ]
