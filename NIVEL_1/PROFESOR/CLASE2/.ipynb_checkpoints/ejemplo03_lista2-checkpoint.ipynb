   "source": [
    "# Declaración de lista de datos\n",
    "datos = [25,37,42,16,88,23,26]\n",
    "# Máximo valor de la lista\n",
    "maximo = max(datos)\n",
    "# Obtener valores normalizados\n",
    "normalizados = [ x / maximo for x in datos]\n",
    "# Imprimir resultados\n",
    "print(f\"Los datos normalizados son {normalizados}\")"
   ]
